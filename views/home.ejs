<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Previous Year Question Papers</title>
  <meta name="google-site-verification" content="l4Po62W6D7u5I9ouFjSz1ei_D1JykPCfTHbtIU-KW0k" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/css/style.css?v=999999">
</head>

<body>

<!-- ===== TOP NAVBAR ===== -->
<nav class="top-navbar">
  <div class="nav-left">
    <img src="/logo.png" alt="SPPU Logo" class="nav-logo-img">
    <div class="nav-text">
      <span class="nav-title">SPPU</span>
      <span class="nav-subtitle">Study Material</span>
    </div>
  </div>

  <div class="nav-center">
    <a href="/">Home</a>
    <a href="/notes">Notes</a>
    <a href="/papers">Question Papers</a>
    <a href="/about">About</a>
  </div>

  <div class="nav-right">
    <% if (currentUser) { %>
      <span class="nav-user-name">👤 <%= currentUser.name %></span>
      <a href="/logout" class="nav-btn">Logout</a>
    <% } else { %>
      <a href="/login" class="nav-btn">Login</a>
    <% } %>
    <div class="hamburger" onclick="toggleMobileMenu()">☰</div>
  </div>
</nav>

<!-- ===== MOBILE SIDEBAR MENU ===== -->
<div class="mobile-menu" id="mobileMenu">
  <a href="/" onclick="toggleMobileMenu()">Home</a>
  <a href="/notes" onclick="toggleMobileMenu()">Notes</a>
  <a href="/about" onclick="toggleMobileMenu()">About</a>
  <a href="/papers" onclick="toggleMobileMenu()">Question Papers</a>
  <% if (currentUser) { %>
    <a href="/logout" onclick="toggleMobileMenu()">Logout</a>
  <% } else { %>
    <a href="/login" onclick="toggleMobileMenu()">Login</a>
  <% } %>
</div>

<div class="container">

  <!-- HEADER -->
  <div class="uni-header">
    <h1>Savitribai Phule Pune University</h1>
    <p>
      Previous Year Question Paper Portal<br>
      Faculty of Engineering
    </p>
  </div>

  <!-- ===== PAGE TITLE ROW WITH UPLOAD BUTTON ===== -->
  <div class="page-title-row">
    <h2 class="page-title">Previous Year Question Papers</h2>
    <div style="display:flex; gap:10px; align-items:center;">
      <% if (isAdmin) { %>
        <a href="/admin/upload" class="note-btn heading-btn" style="background:#4f46e5;">
          + Upload Paper
        </a>
      <% } %>
      <a href="/notes" class="note-btn heading-btn">
        Download Subject-wise Notes
      </a>
    </div>
  </div>

  <div class="full-divider"></div>

  <!-- SEARCH FORM -->
  <form method="GET" action="/papers" class="search-form">
    <select name="branch" id="branch" required>
      <option value="">Branch</option>
      <option value="IT" <%= filters?.branch === "IT" ? "selected" : "" %>>IT</option>
      <option value="CS" <%= filters?.branch === "CS" ? "selected" : "" %>>Computer Science</option>
      <option value="ENTC" <%= filters?.branch === "ENTC" ? "selected" : "" %>>ENTC</option>
      <option value="Mechanical" <%= filters?.branch === "Mechanical" ? "selected" : "" %>>Mechanical</option>
    </select>

    <select name="academicYear">
      <option value="">Year</option>
      <option value="FE" <%= filters?.academicYear === "FE" ? "selected" : "" %>>FE</option>
      <option value="SE" <%= filters?.academicYear === "SE" ? "selected" : "" %>>SE</option>
      <option value="TE" <%= filters?.academicYear === "TE" ? "selected" : "" %>>TE</option>
      <option value="BE" <%= filters?.academicYear === "BE" ? "selected" : "" %>>BE</option>
    </select>

    <select name="semester" required>
      <option value="">Semester</option>
      <option value="1" <%= filters?.semester == 1 ? "selected" : "" %>>Semester 1</option>
      <option value="2" <%= filters?.semester == 2 ? "selected" : "" %>>Semester 2</option>
    </select>

    <select name="subject" id="subject">
      <option value="">Subject</option>
    </select>

    <button type="submit">Search</button>
  </form>

  <!-- ===== RESULTS ===== -->
  <% if (searched && (insemPapers.length > 0 || endsemPapers.length > 0)) { %>

    <div class="results-grid">

      <!-- INSEM SECTION -->
      <div class="result-section">
        <div class="section-header insem-header">
          <h3>📝 Insem Papers</h3>
          <span class="paper-count"><%= insemPapers.length %> papers</span>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Course</th>
                <th>Branch</th>
                <th>Sem</th>
                <th>Subject</th>
                <th>Year</th>
                <th>Download</th>
                <% if (isAdmin) { %><th>Delete</th><% } %>
              </tr>
            </thead>
            <tbody>
              <% if (insemPapers.length === 0) { %>
                <tr>
                  <td colspan="<%= isAdmin ? 7 : 6 %>" class="empty">No insem papers found</td>
                </tr>
              <% } %>
              <% insemPapers.forEach(paper => { %>
                <tr>
                  <td data-label="Course"><%= paper.course %></td>
                  <td data-label="Branch"><%= paper.branch %></td>
                  <td data-label="Sem"><%= paper.semester %></td>
                  <td data-label="Subject"><%= paper.subject %></td>
                  <td data-label="Year"><%= paper.year %></td>
                  <td data-label="Download">
                    <a href="/download/<%= paper._id %>" class="download-btn">Download</a>
                  </td>
                  <% if (isAdmin) { %>
                    <td data-label="Action">
                      <form action="/admin/delete/<%= paper._id %>" method="POST">
                        <button type="submit" class="delete-btn">Delete</button>
                      </form>
                    </td>
                  <% } %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ENDSEM SECTION -->
      <div class="result-section">
        <div class="section-header endsem-header">
          <h3>📄 Endsem Papers</h3>
          <span class="paper-count"><%= endsemPapers.length %> papers</span>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Course</th>
                <th>Branch</th>
                <th>Sem</th>
                <th>Subject</th>
                <th>Year</th>
                <th>Download</th>
                <% if (isAdmin) { %><th>Delete</th><% } %>
              </tr>
            </thead>
            <tbody>
              <% if (endsemPapers.length === 0) { %>
                <tr>
                  <td colspan="<%= isAdmin ? 7 : 6 %>" class="empty">No endsem papers found</td>
                </tr>
              <% } %>
              <% endsemPapers.forEach(paper => { %>
                <tr>
                  <td data-label="Course"><%= paper.course %></td>
                  <td data-label="Branch"><%= paper.branch %></td>
                  <td data-label="Sem"><%= paper.semester %></td>
                  <td data-label="Subject"><%= paper.subject %></td>
                  <td data-label="Year"><%= paper.year %></td>
                  <td data-label="Download">
                    <a href="/download/<%= paper._id %>" class="download-btn">Download</a>
                  </td>
                  <% if (isAdmin) { %>
                    <td data-label="Action">
                      <form action="/admin/delete/<%= paper._id %>" method="POST">
                        <button type="submit" class="delete-btn">Delete</button>
                      </form>
                    </td>
                  <% } %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </div>

  <% } else if (searched) { %>

    <div class="no-results">
      <p>No papers found. Try different filters.</p>
    </div>

  <% } else { %>

    <!-- DEFAULT TABLE (before search) -->
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Course</th>
            <th>Branch</th>
            <th>Semester</th>
            <th>Subject</th>
            <th>Year</th>
            <th>Exam Type</th>
            <th>Download</th>
            <% if (isAdmin) { %><th>Delete</th><% } %>
          </tr>
        </thead>
        <tbody>
          <% if (papers.length === 0) { %>
            <tr>
              <td colspan="<%= isAdmin ? 8 : 7 %>" class="empty">No papers found</td>
            </tr>
          <% } %>
          <% papers.forEach(paper => { %>
            <tr>
              <td data-label="Course"><%= paper.course %></td>
              <td data-label="Branch"><%= paper.branch %></td>
              <td data-label="Semester"><%= paper.semester %></td>
              <td data-label="Subject"><%= paper.subject %></td>
              <td data-label="Year"><%= paper.year %></td>
              <td data-label="Exam Type">
                <span class="exam-badge <%= paper.examType %>">
                  <%= paper.examType === "insem" ? "Insem" : "Endsem" %>
                </span>
              </td>
              <td data-label="Download">
                <a href="/download/<%= paper._id %>" class="download-btn">Download</a>
              </td>
              <% if (isAdmin) { %>
                <td data-label="Action">
                  <form action="/admin/delete/<%= paper._id %>" method="POST">
                    <button type="submit" class="delete-btn">Delete</button>
                  </form>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  <% } %>

</div>

<!-- SUBJECT SCRIPT -->
<script>
const branchSubjects = {
  IT: [
    "Computer Network and Security",
    "Data Science and Big Data Analytics",
    "Web Application Development",
    "Cloud Computing",
    "Artificial Intelligence"
  ],
  CS: [
    "DATA SCIENCE AND BIG DATA ANALYSIS",
    "WEB TECHNOLOGY",
    "ARTIFICIAL INTELLIGENCE",
    "CLOUD COMPUTING",
    "Machine Learning"
  ],
  ENTC: [
    "CELLULAR NETWORKS (CN)",
    "PROJECT MANAGEMENT (PM)",
    "POWER DEVICES AND CIRCUITS (PD & C)",
    "EMBEDDED PROCESSORS (EP)",
    "NETWORK SECURITY (NS)"
  ],
  Mechanical: [
    "SURFACE ENGINEERING (SE)",
    "COMPOSITE MATERIALS (CM)",
    "DESIGN OF TRANSMISSION SYSTEMS (DOTS)",
    "COMPUTER AIDED ENGINEERING (CAE)",
    "ARTIFICIAL INTELLIGENCE AND MACHINE LEARNING (AI ML)"
  ]
};

const branchSelect = document.getElementById("branch");
const subjectSelect = document.getElementById("subject");
const selectedSubject = "<%= filters?.subject || '' %>";

function loadSubjects(branch) {
  subjectSelect.innerHTML = '<option value="">Subject</option>';
  if (!branchSubjects[branch]) return;

  branchSubjects[branch].forEach(sub => {
    const opt = document.createElement("option");
    opt.value = sub;
    opt.textContent = sub;
    if (selectedSubject && sub.toLowerCase() === selectedSubject.toLowerCase()) {
      opt.selected = true;
    }
    subjectSelect.appendChild(opt);
  });
}

branchSelect.addEventListener("change", () => loadSubjects(branchSelect.value));
if (branchSelect.value) loadSubjects(branchSelect.value);
</script>

<script>
  function toggleMobileMenu() {
    document.getElementById("mobileMenu").classList.toggle("active");
  }
</script>

</body>
</html>