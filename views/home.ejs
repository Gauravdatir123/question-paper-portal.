<!DOCTYPE html>
<html>
<head>
  <title>Previous Year Question Papers</title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="container">
 <div class="uni-header">
  <h1>Savitribai Phule Pune University</h1>
  <p>
    Previous Year Question Paper Portal<br>
    Faculty of Engineering
  </p>
</div>
  <h2>Previous Year Question Papers</h2>


  <!-- SEARCH FORM -->
  <form method="GET" action="/" class="search-form">

    <!-- Branch -->
    <select name="branch" id="branch" required>
  <option value="">Branch</option>
  <option value="IT" <%= filters?.branch === "IT" ? "selected" : "" %>>IT</option>
  <option value="CS" <%= filters?.branch === "CS" ? "selected" : "" %>>Computer Science</option>
  <option value="ENTC" <%= filters?.branch === "ENTC" ? "selected" : "" %>>ENTC</option>
  <option value="Mechanical" <%= filters?.branch === "Mechanical" ? "selected" : "" %>>Mechanical</option>
</select>

    <!-- Academic Year (UI only, not filtering now) -->
    <select name="academicYear">
      <option value="">Year</option>
      <option value="FE" <%= filters?.academicYear === "FE" ? "selected" : "" %>>FE</option>
      <option value="SE" <%= filters?.academicYear === "SE" ? "selected" : "" %>>SE</option>
      <option value="TE" <%= filters?.academicYear === "TE" ? "selected" : "" %>>TE</option>
      <option value="BE" <%= filters?.academicYear === "BE" ? "selected" : "" %>>BE</option>
    </select>

    <!-- Semester -->
    <select name="semester" required>
      <option value="">Semester</option>
      <option value="1" <%= filters?.semester == 1 ? "selected" : "" %>>Semester 1</option>
      <option value="2" <%= filters?.semester == 2 ? "selected" : "" %>>Semester 2</option>
    </select>

    <!-- Subject -->
    <select name="subject" id="subject">
      <option value="">Subject</option>
    </select>

    <button type="submit">Search</button>
  </form>

  <!-- TABLE -->
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Course</th>
          <th>Branch</th>
          <th>Semester</th>
          <th>Subject</th>
          <th>Year</th>
          <th>Download</th>

          <% if (typeof isAdmin !== "undefined" && isAdmin) { %>
            <th>Delete</th>
          <% } %>
        </tr>
      </thead>

      <tbody>
        <% if (papers.length === 0) { %>
          <tr>
            <td colspan="<%= isAdmin ? 7 : 6 %>" class="empty">
              No papers found
            </td>
          </tr>
        <% } %>

        <% papers.forEach(paper => { %>
          <tr>
            <td data-label="Course"><%= paper.course %></td>
<td data-label="Branch"><%= paper.branch %></td>
<td data-label="Semester"><%= paper.semester %></td>
<td data-label="Subject"><%= paper.subject %></td>
<td data-label="Year"><%= paper.year %></td>
<td data-label="Download">
  <a href="/download/<%= paper._id %>" class="download-btn">Download</a>
</td>
              <a href="/download/<%= paper._id %>" class="download-btn">Download</a>
            </td>

            <% if (typeof isAdmin !== "undefined" && isAdmin) { %>
              <td>
                <form action="/admin/delete/<%= paper._id %>" method="POST">
                  <button class="delete-btn">Delete</button>
                </form>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</div>

<!-- ================= SUBJECT SCRIPT (FIXED) ================= -->
<script>
  const branchSubjects = {
    IT: [
      "Computer and Network Security",
      "Data Science and Big Data Analytics",
      "Web Application Development",
      "Cloud Computing",
      "Artificial Intelligence"
    ],
    CS: [
      "DATA SCIENCE AND BIG DATA ANALYSIS",
      "WEB TECHNOLOGY",
      "ARTIFICIAL INTELLIGENCE",
      "CLOUD COMPUTING",
      "Machine Learning"
    ],
    ENTC: [
    "CELLULAR NETWORKS (CN)",
    "PROJECT MANAGEMENT (PM)",
    "POWER DEVICES AND CIRCUITS (PD & C)",
    "EMBEDDED PROCESSORS (EP)",
    "NETWORK SECURITY (NS)"
  ],
    Mechanical: [
      "Thermodynamics",
      "Fluid Mechanics",
      "Machine Design",
      "Heat Transfer"
    ]
  };

  const branchSelect = document.getElementById("branch");
  const subjectSelect = document.getElementById("subject");

  // value coming from backend
  const selectedSubject = "<%= filters?.subject || "" %>";

  function loadSubjects(branch) {
    subjectSelect.innerHTML = '<option value="">Subject</option>';

    if (!branchSubjects[branch]) return;

    branchSubjects[branch].forEach(sub => {
      const opt = document.createElement("option");
      opt.value = sub;
      opt.textContent = sub;

      // ✅ restore selected subject after search
      if (
        selectedSubject &&
        sub.toLowerCase() === selectedSubject.toLowerCase()
      ) {
        opt.selected = true;
      }

      subjectSelect.appendChild(opt);
    });
  }

  // On branch change
  branchSelect.addEventListener("change", () => {
    loadSubjects(branchSelect.value);
  });

  // ✅ On page reload (after search)
  if (branchSelect.value) {
    loadSubjects(branchSelect.value);
  }
</script>

</body>
</html>