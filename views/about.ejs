<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About | SPPU Question Paper Portal</title>
  <link rel="stylesheet" href="/css/style2.css" />
  <link rel="stylesheet" href="/css/style.css?v=999999">

  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
<nav class="top-navbar">
  <div class="nav-left">
    <img src="/logo.png" alt="SPPU Logo" class="nav-logo-img">
    <div class="nav-text">
      <span class="nav-title">SPPU</span>
      <span class="nav-subtitle">Study Material</span>
    </div>
  </div>

  <div class="nav-center">
    <a href="/">Home</a>
    <a href="/notes">Notes</a>
    
    <a href="/">Question Papers</a>
    <a href="/">About</a>
  </div>

  <div class="nav-right">
     <a href="" class="nav-btn">User</a>
    <!-- Hamburger icon (mobile) -->
    <div class="hamburger" onclick="toggleMobileMenu()">☰</div>

    <!-- User button -->
  </div>
</nav>

<!-- MOBILE SIDEBAR -->
<div class="mobile-menu" id="mobileMenu">
  <a href="/" onclick="toggleMobileMenu()">Home</a>
  <a href="/notes" onclick="toggleMobileMenu()">Notes</a>
  <a href="/" onclick="toggleMobileMenu()">About</a>
  <a href="/" onclick="toggleMobileMenu()">Question Papers</a>
</div>
<!-- ===== MOBILE SIDEBAR MENU ===== -->
<div class="mobile-menu" id="mobileMenu">
  <a href="/" onclick="toggleMobileMenu()">Home</a>
  <a href="/notes" onclick="toggleMobileMenu()">Notes</a>
  <a href="/about" onclick="toggleMobileMenu()">About</a>
  <a href="/contact" onclick="toggleMobileMenu()">Contact</a>
</div>
<div class="about-wrapper">

  <!-- Hero Banner -->
  <div class="about-hero">
    <div class="hero-badge">SPPU Portal</div>
    <h1 class="hero-title">About the Portal</h1>
    <p class="hero-sub">A student-built platform for organized, fast access to SPPU question papers.</p>
  </div>

  <!-- Developer Cards -->
  <section class="dev-section">
    <h2 class="section-label">👨‍💻 Meet the Developers</h2>
    <div class="dev-cards">

      <!-- Developer 1 -->
      <div class="dev-card">
        <div class="dev-avatar">
          <img src="/images/dev1.jpg" alt="Gaurav Datir" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"/>
          <div class="avatar-fallback">GD</div>
        </div>
        <div class="dev-info">
          <h3 class="dev-name">Gaurav Datir</h3>
          <span class="dev-role">Full Stack Developer</span>
          <p class="dev-desc">Information Technology Student at SPPU. Built the backend, admin panel, and cloud storage integrations.</p>
          <div class="dev-tags">
            <span>Node.js</span>
            <span>MongoDB</span>
            <span>EJS</span>
          </div>
        </div>
      </div>

      <!-- Developer 2 -->
      <div class="dev-card">
        <div class="dev-avatar">
          <img src="/public /dev2.jpg" alt="Friend Name" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"/>
          <div class="avatar-fallback">KD</div>
        </div>
        <div class="dev-info">
          <h3 class="dev-name">Kunal Dongare</h3>
          <span class="dev-role">Full Stack Developer</span>
          <p class="dev-desc">Computer Engineering Student at SPPU. Designed the UI, layouts, and student-facing features.</p>
          <div class="dev-tags">
            <span>CSS</span>
            <span>JavaScript</span>
            <span>UI/UX</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- About Content -->
  <section class="about-content">

    <div class="about-card">
      <div class="about-card-icon">📘</div>
      <div>
        <h3>What is this Platform?</h3>
        <p>
          The <strong>Question Paper Portal</strong> is designed to help students easily access previous year question papers across different branches, semesters, and subjects under
          <strong>Savitribai Phule Pune University (SPPU)</strong>. No more searching scattered drives or outdated groups — everything is organized in one place.
        </p>
      </div>
    </div>

    <div class="about-card">
      <div class="about-card-icon">🎯</div>
      <div>
        <h3>Our Goal</h3>
        <p>We aim to simplify exam preparation by offering a structured, clean, and reliable resource hub for SPPU students.</p>
        <ul class="goal-list">
          <li>✔ Subject-wise organized papers</li>
          <li>✔ Branch &amp; semester-based filtering</li>
          <li>✔ Fast, secure downloads via Cloudinary</li>
          <li>✔ Admin-managed uploads with easy controls</li>
        </ul>
      </div>
    </div>

    <div class="about-card">
      <div class="about-card-icon">🏫</div>
      <div>
        <h3>University Focus</h3>
        <p>
          This portal is exclusively built for students of
          <strong>Savitribai Phule Pune University (SPPU)</strong>, one of the largest universities in India. Whether you're in Engineering, Science, or Commerce — find your papers here.
        </p>
      </div>
    </div>

    
  </section>

  <div class="about-footer">
    <a href="/" class="download-btn">⬅ Back to Home</a>
    <p>Built with ❤️ for SPPU Students</p>
  </div>

</div>
<script>
  function toggleMobileMenu() {
    document.getElementById("mobileMenu").classList.toggle("active");
  }
</script>
</body>
</html>